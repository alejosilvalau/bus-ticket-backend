# REST Client file Inventory

### Create a new trip
POST http://localhost:8080/api/v1/journeys/inventory/trips
Content-Type: application/json
Authorization: Bearer eyJhbGciOiJIUzM4NCJ9.eyJzdWIiOiIxIiwiZW1haWwiOiJqb2huLmRvZUBlbWFpbC5jb20iLCJpc0FkbWluIjp0cnVlLCJpYXQiOjE3ODE4ODQ4ODcsImV4cCI6MTc4MTg5NTY4N30.1U0zGRV0dFgcjpAMgbnKCnFp0fIadVGBBki28EcKhCxIWOJEZrkwpLmLPx0rGqXg

{
  "departureDate": "2039-12-01T08:00:00Z",
  "arrivalDate": "2039-12-01T14:00:00Z",
  "basePrice": 150.00,
  "busId": 2,
  "driverId": 3,
  "locationOriginId": 1,
  "locationDestinationId": 2
}

### Update trip by ID
PATCH http://localhost:8080/api/v1/journeys/inventory/trips
Content-Type: application/json
Authorization: Bearer eyJhbGciOiJIUzM4NCJ9.eyJzdWIiOiIxIiwiZW1haWwiOiJqb2huLmRvZUBlbWFpbC5jb20iLCJpc0FkbWluIjp0cnVlLCJpYXQiOjE3ODE4ODQ4ODcsImV4cCI6MTc4MTg5NTY4N30.1U0zGRV0dFgcjpAMgbnKCnFp0fIadVGBBki28EcKhCxIWOJEZrkwpLmLPx0rGqXg

{
  "id": 2,
  "departureDate": 300.00
}

### Delete trip by ID
DELETE http://localhost:8080/api/v1/journeys/inventory/trips/1
Accept: application/json
Authorization: Bearer eyJhbGciOiJIUzM4NCJ9.eyJzdWIiOiIxIiwiZW1haWwiOiJqb2huLmRvZUBlbWFpbC5jb20iLCJpc0FkbWluIjp0cnVlLCJpYXQiOjE3ODE4ODQ4ODcsImV4cCI6MTc4MTg5NTY4N30.1U0zGRV0dFgcjpAMgbnKCnFp0fIadVGBBki28EcKhCxIWOJEZrkwpLmLPx0rGqXg

### Create a new location
POST http://localhost:8080/api/v1/journeys/inventory/locations
Content-Type: application/json
Authorization: Bearer eyJhbGciOiJIUzM4NCJ9.eyJzdWIiOiIxIiwiZW1haWwiOiJqb2huLmRvZUBlbWFpbC5jb20iLCJpc0FkbWluIjp0cnVlLCJpYXQiOjE3ODE2NDE3MjgsImV4cCI6MTc4MTY1MjUyOH0.owSyuuAabW6v1sIO7S5CLD0iUE3ds7fAKpvtE_UdKxbfRxxIAV5Jq3kQPFlxUmH_

{
  "cityName": "Buenos Aires",
  "state": "BA",
  "postalCode": "1000"
}

